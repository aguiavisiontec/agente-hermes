# ────────────────────────────────────────────────────
# Agente Hermes — Variáveis de Ambiente
# Aguiavision Tecnologia
# ────────────────────────────────────────────────────
# Copie este arquivo para .env e preencha com suas chaves API.
# NUNCA commite este arquivo com chaves reais!
#
# IMPORTANTE: Preencha PELO MENOS UM provedor de inferência
# abaixo, senão o agente não conseguirá se comunicar com
# nenhum modelo de IA e retornará erro 401.
# ────────────────────────────────────────────────────

# Chave de acesso ao API Server (para o Desktop App se conectar remotamente)
API_SERVER_KEY=hermes-aguiavision-2026

# ── Provedores de Inferência ──
# Preencha PELO MENOS UM dos provedores abaixo:

# OpenRouter (recomendado — 200+ modelos, inclui DeepSeek, Llama, etc.)
OPENROUTER_API_KEY=sk-or-v1-sua-chave-aqui

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-sua-chave-aqui

# OpenAI (GPT)
# OPENAI_API_KEY=sk-sua-chave-aqui

# Google AI Studio (Gemini)
# GOOGLE_API_KEY=AIza-sua-chave-aqui

# Groq (inferência rápida)
# GROQ_API_KEY=gsk_sua-chave-aqui

# DeepSeek
# DEEPSEEK_API_KEY=sk-sua-chave-aqui

# ── Ferramentas ──
# Pesquisa web
# EXA_API_KEY=sua-chave-aqui
# TAVIL_API_KEY=tvly-sua-chave-aqui

# Geração de imagens
# FAL_KEY=sua-chave-aqui

# ── Proxy Anthropic (já existe na sua stack) ──
# Se quiser usar o proxy-anthropic local:
# ANTHROPIC_BASE_URL=http://proxy-anthropic:4000
